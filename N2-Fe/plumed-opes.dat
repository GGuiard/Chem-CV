UNITS LENGTH=A

c: COORDINATION GROUPA=73,74 GROUPB=1-72 R_0=2.5 NN=6 MM=12
d: DISTANCE ATOMS=73,74
com: COM ATOMS=73,74

UPPER_WALLS ARG=d AT=2 KAPPA=0.2 EXP=2 EPS=0.1
UPPER_WALLS ARG=com.z AT=10 KAPPA=1

opes: OPES_METAD_EXPLORE ARG=c,d PACE=100 BARRIER=1 TEMP=700

PRINT STRIDE=1 ARG=c,d,opes.bias FILE=COLVAR
FLUSH STRIDE=100