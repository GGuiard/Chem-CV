UNITS LENGTH=A ENERGY=eV

fe: GROUP ATOMS=1-72
nn: GROUP ATOMS=73,74

d: DISTANCE ATOMS=73,74
com: COM ATOMS=nn
c: COORDINATION GROUPA=nn GROUPB=fe R_0=2.5

UPPER_WALLS ARG=d AT=2 KAPPA=0.2 EXP=2 EPS=0.1
UPPER_WALLS ARG=com.z AT=8 KAPPA=1

opes: OPES_METAD_EXPLORE ARG=d,c PACE=100 BARRIER=1 TEMP=700 STATE_WFILE=STATES STATE_WSTRIDE=1*100

PRINT STRIDE=1 ARG=d,c,com.x,com.y,com.z,opes.bias FILE=COLVAR
FLUSH STRIDE=100