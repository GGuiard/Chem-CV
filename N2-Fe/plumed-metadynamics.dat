UNITS LENGTH=A ENERGY=eV

d: DISTANCE ATOMS=73,74
com: COM ATOMS=73,74
c: COORDINATION GROUPA=73,74 GROUPB=1-72 R_0=2.5

UPPER_WALLS ARG=d AT=2 KAPPA=0.2 EXP=2 EPS=0.1
UPPER_WALLS ARG=com.z AT=8 KAPPA=1

metad: METAD ARG=d,c PACE=100 HEIGHT=0.1 BIASFACTOR=8 SIGMA=0.1,0.1 TEMP=700

PRINT STRIDE=1 ARG=d,c,com.x,com.y,com.z,metad.bias FILE=COLVAR
FLUSH STRIDE=100